# Auto detect text files and perform LF normalization
* text=auto eol=lf

*.bat text eol=crlf

docs/** linguist-documentation=false
docs/** linguist-detectable=true

*.js linguist-language=JavaScript
*.html linguist-language=HTML
*.php linguist-language=PHP
*.twig linguist-language=PHP

*.bat linguist-vendored=true
*.css linguist-vendored=true
*.go linguist-vendored=true
go.mod linguist-vendored=true
go.sum linguist-vendored=true